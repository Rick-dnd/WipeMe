---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import JsonLd from '../../components/JsonLd.astro';
import ContentNav from '../../components/ContentNav.astro';
import { getAlternates, getCanonicalUrl } from '../../lib/seo.ts';
import Footer from '../../components/Footer.astro';

export const prerender = true;

const webPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Why WipeMe?',
  url: getCanonicalUrl('/en/why'),
  description: 'Why data deletion matters and what makes WipeMe different from other privacy tools.',
  inLanguage: 'en',
  isPartOf: {
    '@type': 'WebSite',
    name: 'WipeMe',
    url: 'https://wipeme.cc',
  },
};

const breadcrumbItems = [
  { name: 'WipeMe', url: 'https://wipeme.cc/en/' },
  { name: 'Why WipeMe', url: 'https://wipeme.cc/en/why' },
];
---

<Layout
  title="Why WipeMe? — WipeMe"
  description="Delete your data, reclaim your digital privacy. Why the right to erasure matters and how WipeMe's zero-knowledge approach makes the difference."
  lang="en"
  canonical="https://wipeme.cc/en/why"
  alternates={getAlternates('/why', '/en/why')}
>
  <Fragment slot="head">
    <JsonLd data={webPageJsonLd} />
  </Fragment>

  <ContentNav lang="en" currentPath="why" />

  <main class="pt-28 pb-24 px-6">
    <div class="max-w-2xl mx-auto">

      <Breadcrumbs items={breadcrumbItems} />

      <div class="mb-12 reveal delay-1">
        <p class="pill bg-[var(--color-forest)]/[0.06] text-[var(--color-forest)] border border-[var(--color-forest)]/10 mb-6">
          Background
        </p>
        <h1 class="headline-serif text-4xl md:text-5xl text-[var(--color-ink)] mb-4">
          Why WipeMe?
        </h1>
        <p class="text-[var(--color-ink-muted)] text-[15px]">
          Your data, your decision — what is at stake and how WipeMe helps.
        </p>
      </div>

      <section class="card p-8 mb-6 reveal delay-2">
        <h2 class="text-lg font-semibold text-[var(--color-ink)] mb-4">
          The Problem
        </h2>
        <p class="text-[var(--color-ink-muted)] text-[15px] leading-relaxed mb-4">
          You sign up for a new service — a newsletter here, a customer account there, an app
          you tried once. Eventually you forget about it. But the companies do not forget you.
        </p>
        <p class="text-[var(--color-ink-muted)] text-[15px] leading-relaxed mb-5">
          Hundreds of services hold your email address, your name, possibly your postal address
          or your purchase history. Data breaches, third-party data sharing, unwanted contact —
          the consequences can surface years later.
        </p>
        <div class="rounded-xl bg-[var(--color-forest)]/[0.04] border border-[var(--color-forest)]/10 p-5">
          <p class="text-[var(--color-ink-muted)] text-[15px] leading-relaxed">
            <strong class="text-[var(--color-ink)] font-medium">Privacy law gives you the right</strong> to
            change this. GDPR Art. 17, CCPA, UK GDPR — these regulations require companies to delete
            your data on request. The problem: contacting every service individually is time-consuming,
            frustrating, and simply unrealistic when you think about dozens or hundreds of services.
          </p>
        </div>
      </section>

      <section class="card p-8 mb-6 reveal delay-3">
        <h2 class="text-lg font-semibold text-[var(--color-ink)] mb-4">
          The Solution
        </h2>
        <p class="text-[var(--color-ink-muted)] text-[15px] leading-relaxed mb-5">
          WipeMe automates the process. Your inbox is the memory of your digital past — every
          sign-up confirmation you have ever received is a clue to a service that still holds
          your data.
        </p>
        <ul class="space-y-4 text-[15px] text-[var(--color-ink-muted)]">
          <li class="flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-[var(--color-forest)] text-white flex items-center justify-center text-xs font-semibold shrink-0 mt-0.5">1</div>
            <div>
              <p class="text-[var(--color-ink)] font-medium mb-1">Scan your inbox</p>
              <p>WipeMe connects once via IMAP and scans your inbox for sign-up confirmations — without reading the body of any email.</p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-[var(--color-sage)] text-white flex items-center justify-center text-xs font-semibold shrink-0 mt-0.5">2</div>
            <div>
              <p class="text-[var(--color-ink)] font-medium mb-1">Identify services</p>
              <p>Over 2,700 companies are listed in the company directory, complete with privacy contact emails, web forms, and regional legal frameworks.</p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-[var(--color-teal)] text-white flex items-center justify-center text-xs font-semibold shrink-0 mt-0.5">3</div>
            <div>
              <p class="text-[var(--color-ink)] font-medium mb-1">Send deletion requests</p>
              <p>WipeMe generates legally appropriate requests and sends them directly from your own email account. Minutes instead of hours.</p>
            </div>
          </li>
        </ul>
      </section>

      <section class="card p-8 mb-6 reveal delay-3">
        <h2 class="text-lg font-semibold text-[var(--color-ink)] mb-4">
          Why Different?
        </h2>
        <p class="text-[var(--color-ink-muted)] text-[15px] leading-relaxed mb-5">
          Most privacy tools solve one problem by creating another: they collect your data
          centrally and become a trust problem themselves. WipeMe takes a different approach.
        </p>
        <ul class="space-y-3 text-[15px] text-[var(--color-ink-muted)]">
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-[var(--color-sage)] mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <span>
              <strong class="text-[var(--color-ink)] font-medium">Zero-knowledge architecture</strong> —
              no database, no user accounts, no server-side storage.
              Everything runs in your browser.
            </span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-[var(--color-sage)] mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <span>
              <strong class="text-[var(--color-ink)] font-medium">AES-256-GCM encryption</strong> —
              your email credentials are encrypted client-side. The server processes them only
              transiently in RAM and discards them immediately.
            </span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-[var(--color-sage)] mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <span>
              <strong class="text-[var(--color-ink)] font-medium">Open source under MIT</strong> —
              the full source code is public. You do not have to trust WipeMe —
              you can verify it.
            </span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-[var(--color-sage)] mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <span>
              <strong class="text-[var(--color-ink)] font-medium">Self-hostable</strong> —
              you can run WipeMe on your own infrastructure,
              fully under your control.
            </span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-[var(--color-sage)] mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <span>
              <strong class="text-[var(--color-ink)] font-medium">No cookies, no tracking, no advertising</strong> —
              WipeMe does not make money from your data. There simply is none to sell.
            </span>
          </li>
        </ul>
      </section>

      <section class="card p-8 mb-8 reveal delay-4">
        <h2 class="text-lg font-semibold text-[var(--color-ink)] mb-4">
          Your Rights
        </h2>
        <p class="text-[var(--color-ink-muted)] text-[15px] leading-relaxed mb-5">
          The right to data deletion exists in various forms around the world.
          WipeMe understands the regional differences and generates the appropriate requests accordingly.
        </p>
        <div class="space-y-3">
          <div class="flex items-start gap-4 text-[15px]">
            <span class="text-[var(--color-forest)] font-semibold shrink-0 w-24 pt-0.5">EU / EEA</span>
            <div>
              <p class="text-[var(--color-ink)] font-medium mb-0.5">GDPR — Art. 17</p>
              <p class="text-[var(--color-ink-muted)]">Right to erasure, 30-day deadline, supervisory authorities in every member state.</p>
            </div>
          </div>
          <div class="h-px bg-[var(--color-sand)]"></div>
          <div class="flex items-start gap-4 text-[15px]">
            <span class="text-[var(--color-forest)] font-semibold shrink-0 w-24 pt-0.5">United Kingdom</span>
            <div>
              <p class="text-[var(--color-ink)] font-medium mb-0.5">UK GDPR</p>
              <p class="text-[var(--color-ink-muted)]">Largely equivalent to EU GDPR, oversight by the ICO.</p>
            </div>
          </div>
          <div class="h-px bg-[var(--color-sand)]"></div>
          <div class="flex items-start gap-4 text-[15px]">
            <span class="text-[var(--color-forest)] font-semibold shrink-0 w-24 pt-0.5">USA</span>
            <div>
              <p class="text-[var(--color-ink)] font-medium mb-0.5">CCPA (California)</p>
              <p class="text-[var(--color-ink-muted)]">Right to Delete for California residents, specific requirements for request wording.</p>
            </div>
          </div>
          <div class="h-px bg-[var(--color-sand)]"></div>
          <div class="flex items-start gap-4 text-[15px]">
            <span class="text-[var(--color-forest)] font-semibold shrink-0 w-24 pt-0.5">Brazil</span>
            <div>
              <p class="text-[var(--color-ink)] font-medium mb-0.5">LGPD</p>
              <p class="text-[var(--color-ink-muted)]">Lei Geral de Proteção de Dados, similar fundamental rights to GDPR.</p>
            </div>
          </div>
        </div>
      </section>

      <div class="rounded-2xl bg-[var(--color-forest)] p-8 text-center reveal delay-4">
        <h2 class="headline-serif text-2xl text-white mb-3">
          Ready to reclaim your data?
        </h2>
        <p class="text-white/70 text-[15px] mb-6">
          Connect your inbox, discover where your data lives,
          and send deletion requests in minutes.
        </p>
        <a
          href="/en/app"
          class="inline-flex items-center gap-2 bg-white text-[var(--color-forest)] font-semibold text-[15px] px-6 py-3 rounded-full hover:bg-[var(--color-cream)] transition-colors"
        >
          Get started
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

      <div class="mt-10 reveal delay-5">
        <a
          href="/en/"
          class="inline-flex items-center gap-2 text-sm text-[var(--color-ink-muted)] hover:text-[var(--color-forest)] transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to home
        </a>
      </div>

    </div>
  </main>

  <Footer lang="en" currentPath="why" />

</Layout>
