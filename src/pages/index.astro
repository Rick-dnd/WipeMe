---
import Layout from '../layouts/Layout.astro';
import LandingLanguageToggle from '../components/LandingLanguageToggle.astro';
import JsonLd from '../components/JsonLd.astro';
import Footer from '../components/Footer.astro';
import { landingTranslations } from '../lib/landing-translations';
import { getAlternates, generateWebAppJsonLd, generateOrganizationJsonLd } from '../lib/seo';
export const prerender = true;

const lang = 'de';
const t = landingTranslations.de;
const alternates = getAlternates('/', '/en/');
---

<Layout title="WipeMe — Hol dir deine Daten zurück" lang={lang} alternates={alternates}>
  <Fragment slot="head">
    <JsonLd data={generateWebAppJsonLd()} />
    <JsonLd data={generateOrganizationJsonLd()} />
  </Fragment>

  <nav class="fixed top-0 w-full z-50 bg-[var(--color-cream)]/80 backdrop-blur-xl border-b border-[var(--color-sand)]/60">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 group">
        <img src="/logo.svg" alt="WipeMe" class="w-7 h-7 transition-transform group-hover:rotate-[-8deg]" />
        <span class="text-base font-semibold text-[var(--color-forest)] font-[var(--font-body)]">WipeMe</span>
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="#how-it-works" class="text-sm text-[var(--color-ink-muted)] hover:text-[var(--color-forest)] transition-colors">{t['nav-howitworks']}</a>
        <a href="#privacy" class="text-sm text-[var(--color-ink-muted)] hover:text-[var(--color-forest)] transition-colors">{t['nav-privacy']}</a>
        <a href="#open-source" class="text-sm text-[var(--color-ink-muted)] hover:text-[var(--color-forest)] transition-colors">{t['nav-opensource']}</a>
      </div>
      <div class="flex items-center gap-3">
        <LandingLanguageToggle lang={lang} currentPath="" />
        <a href="https://github.com" target="_blank" class="text-sm text-[var(--color-ink-muted)] hover:text-[var(--color-forest)] transition-colors hidden sm:block">GitHub</a>
        <a href="/app" class="px-5 py-2 text-sm font-medium rounded-full bg-[var(--color-forest)] text-white hover:bg-[var(--color-forest-light)] transition-all hover:shadow-lg hover:shadow-[var(--color-forest)]/15">
          {t['nav-cta']}
        </a>
      </div>
    </div>
  </nav>


  <section class="relative pt-28 pb-8 px-6 overflow-hidden">
    <div class="absolute top-20 right-[10%] w-[400px] h-[400px] bg-[var(--color-mint)]/[0.04] rounded-full blur-[100px] pointer-events-none"></div>
    <div class="absolute top-40 left-[5%] w-[300px] h-[300px] bg-[var(--color-teal)]/[0.03] rounded-full blur-[80px] pointer-events-none"></div>

    <div class="relative max-w-4xl mx-auto text-center">
      <div class="reveal delay-1">
        <span class="pill bg-[var(--color-forest)]/[0.06] text-[var(--color-forest)] border border-[var(--color-forest)]/10">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-mint)] animate-pulse"></span>
          <span>{t['hero-badge']}</span>
        </span>
      </div>

      <h1 class="headline-serif text-5xl md:text-6xl lg:text-[4.5rem] text-[var(--color-ink)] mt-8 mb-6 reveal delay-2">
        <span>{t['hero-h1-1']}</span><br/>
        <span class="text-[var(--color-sage)] italic">{t['hero-h1-2']}</span>
      </h1>

      <p class="text-lg md:text-xl text-[var(--color-ink-muted)] max-w-2xl mx-auto mb-10 leading-relaxed font-light reveal delay-3">
        {t['hero-sub']}
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 reveal delay-4">
        <a href="/app" class="px-7 py-3 rounded-full bg-[var(--color-forest)] text-white font-medium text-[15px] hover:bg-[var(--color-forest-light)] transition-all hover:shadow-xl hover:shadow-[var(--color-forest)]/15 hover:-translate-y-0.5">
          {t['hero-cta1']}
        </a>
        <a href="#how-it-works" class="px-7 py-3 rounded-full text-[var(--color-ink-light)] font-medium text-[15px] border border-[var(--color-sand)] hover:border-[var(--color-ink-muted)] transition-all">
          {t['hero-cta2']}
        </a>
      </div>
    </div>
  </section>


  <section class="px-6 py-12">
    <div class="max-w-5xl mx-auto reveal-scale delay-5">
      <div class="mockup-frame p-1.5 overflow-hidden">
        <div class="flex items-center gap-2 px-4 py-3 bg-[var(--color-cream)] rounded-t-lg border-b border-[var(--color-sand)]/60">
          <div class="flex gap-1.5">
            <div class="w-3 h-3 rounded-full bg-[#FF5F57]"></div>
            <div class="w-3 h-3 rounded-full bg-[#FEBC2E]"></div>
            <div class="w-3 h-3 rounded-full bg-[#28C840]"></div>
          </div>
          <div class="flex-1 flex justify-center">
            <div class="px-4 py-1 rounded-md bg-white text-xs text-[var(--color-ink-muted)] border border-[var(--color-sand)]/80 font-mono">
              localhost:4321/app
            </div>
          </div>
        </div>
        <div class="bg-[var(--color-cream)] p-8 md:p-12 rounded-b-lg">
          <div class="max-w-lg mx-auto">
            <div class="flex items-center justify-center gap-1.5 mb-8">
              <div class="w-2.5 h-2.5 rounded-full bg-[var(--color-forest)]"></div>
              <div class="w-6 h-px bg-[var(--color-sand)]"></div>
              <div class="w-2 h-2 rounded-full bg-[var(--color-sand)]"></div>
              <div class="w-6 h-px bg-[var(--color-sand)]"></div>
              <div class="w-2 h-2 rounded-full bg-[var(--color-sand)]"></div>
            </div>
            <div class="bg-white border border-[var(--color-sand)] rounded-2xl p-8">
              <h3 class="text-xl font-semibold text-[var(--color-forest)] text-center mb-2">{t['mockup-title']}</h3>
              <p class="text-[var(--color-ink-muted)] text-sm text-center mb-6">{t['mockup-sub']}</p>
              <div class="relative mb-4">
                <div class="w-full px-4 py-3.5 rounded-xl bg-white border border-[var(--color-sage)]/30 text-[var(--color-ink)] text-sm flex items-center justify-between">
                  <span>user@gmail.com</span>
                  <span class="px-2 py-0.5 rounded bg-red-50 text-red-600 text-xs font-medium">Gmail</span>
                </div>
              </div>
              <div class="flex items-center gap-2 text-[var(--color-sage)] text-xs mb-6">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                <span>{t['mockup-detected']}</span>
              </div>
              <div class="w-full py-3 rounded-xl bg-[var(--color-forest)] text-white text-sm font-semibold text-center">
                {t['mockup-next']}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <section class="py-12 px-6">
    <div class="max-w-4xl mx-auto text-center reveal delay-1">
      <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-ink-muted)] mb-6 font-medium">{t['providers-label']}</p>
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-14 opacity-60">
        {[
          { name: 'Gmail', logo: '/providers/gmail.svg' },
          { name: 'Outlook', logo: '/providers/outlook.svg' },
          { name: 'GMX', logo: '/providers/gmx.svg' },
          { name: 'web.de', logo: '/providers/webde.svg' },
          { name: 'Yahoo', logo: '/providers/yahoo.svg' },
          { name: 'iCloud', logo: '/providers/icloud.svg' },
          { name: 'ProtonMail', logo: '/providers/protonmail.svg' },
        ].map(p => (
          <div class="flex items-center gap-2 hover:opacity-100 transition-opacity">
            <img src={p.logo} alt={p.name} class="w-6 h-6" />
            <span class="text-sm font-medium text-[var(--color-ink)] tracking-tight hidden sm:inline">{p.name}</span>
          </div>
        ))}
      </div>
    </div>
  </section>


  <section id="how-it-works" class="py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="pill bg-[var(--color-forest)]/[0.06] text-[var(--color-forest)] border border-[var(--color-forest)]/10 mb-6 reveal">{t['steps-badge']}</p>
        <h2 class="headline-serif text-4xl md:text-5xl text-[var(--color-ink)] reveal delay-1">
          <span>{t['steps-h2-1']}</span><br/><span class="italic text-[var(--color-sage)]">{t['steps-h2-2']}</span>
        </h2>
      </div>
      <div class="grid md:grid-cols-3 gap-5">
        <div class="card p-8 reveal delay-2">
          <div class="w-10 h-10 rounded-full bg-[var(--color-forest)] text-white flex items-center justify-center text-sm font-semibold mb-6">1</div>
          <h3 class="text-lg font-semibold text-[var(--color-ink)] mb-3">{t['step1-title']}</h3>
          <p class="text-[var(--color-ink-muted)] leading-relaxed text-[15px]">{t['step1-desc']}</p>
        </div>
        <div class="card p-8 reveal delay-3">
          <div class="w-10 h-10 rounded-full bg-[var(--color-sage)] text-white flex items-center justify-center text-sm font-semibold mb-6">2</div>
          <h3 class="text-lg font-semibold text-[var(--color-ink)] mb-3">{t['step2-title']}</h3>
          <p class="text-[var(--color-ink-muted)] leading-relaxed text-[15px]">{t['step2-desc']}</p>
        </div>
        <div class="card p-8 reveal delay-4">
          <div class="w-10 h-10 rounded-full bg-[var(--color-teal)] text-white flex items-center justify-center text-sm font-semibold mb-6">3</div>
          <h3 class="text-lg font-semibold text-[var(--color-ink)] mb-3">{t['step3-title']}</h3>
          <p class="text-[var(--color-ink-muted)] leading-relaxed text-[15px]">{t['step3-desc']}</p>
        </div>
      </div>
    </div>
  </section>


  <section class="py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="pill bg-[var(--color-forest)]/[0.06] text-[var(--color-forest)] border border-[var(--color-forest)]/10 mb-6 reveal">{t['features-badge']}</p>
        <h2 class="headline-serif text-4xl md:text-5xl text-[var(--color-ink)] reveal delay-1">
          <span>{t['features-h2-1']}</span><br/><span class="italic text-[var(--color-sage)]">{t['features-h2-2']}</span>
        </h2>
      </div>
      <div class="grid md:grid-cols-3 gap-5">
        <div class="card p-8 reveal delay-2">
          <h3 class="text-base font-semibold text-[var(--color-ink)] mb-2">{t['f1-title']}</h3>
          <p class="text-[var(--color-ink-muted)] text-[15px] leading-relaxed">{t['f1-desc']}</p>
        </div>
        <div class="card p-8 reveal delay-3">
          <h3 class="text-base font-semibold text-[var(--color-ink)] mb-2">{t['f2-title']}</h3>
          <p class="text-[var(--color-ink-muted)] text-[15px] leading-relaxed">{t['f2-desc']}</p>
        </div>
        <div class="card p-8 reveal delay-4">
          <h3 class="text-base font-semibold text-[var(--color-ink)] mb-2">{t['f3-title']}</h3>
          <p class="text-[var(--color-ink-muted)] text-[15px] leading-relaxed">{t['f3-desc']}</p>
        </div>
        <div class="card p-8 reveal delay-2">
          <h3 class="text-base font-semibold text-[var(--color-ink)] mb-2">{t['f4-title']}</h3>
          <p class="text-[var(--color-ink-muted)] text-[15px] leading-relaxed">{t['f4-desc']}</p>
        </div>
        <div class="card p-8 reveal delay-3">
          <h3 class="text-base font-semibold text-[var(--color-ink)] mb-2">{t['f5-title']}</h3>
          <p class="text-[var(--color-ink-muted)] text-[15px] leading-relaxed">{t['f5-desc']}</p>
        </div>
        <div class="card p-8 reveal delay-4">
          <h3 class="text-base font-semibold text-[var(--color-ink)] mb-2">{t['f6-title']}</h3>
          <p class="text-[var(--color-ink-muted)] text-[15px] leading-relaxed">{t['f6-desc']}</p>
        </div>
      </div>
    </div>
  </section>


  <section id="privacy" class="py-24 px-6 bg-[var(--color-cream-dark)]/50">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="pill bg-white text-[var(--color-forest)] border border-[var(--color-sand)] mb-6 reveal">{t['privacy-badge']}</p>
        <h2 class="headline-serif text-4xl md:text-5xl text-[var(--color-ink)] reveal delay-1">
          <span>{t['privacy-h2-1']}</span><br/><span class="italic text-[var(--color-sage)]">{t['privacy-h2-2']}</span>
        </h2>
        <p class="text-[var(--color-ink-muted)] mt-4 max-w-lg mx-auto reveal delay-2">{t['privacy-sub']}</p>
      </div>
      <div class="grid md:grid-cols-2 gap-5">
        <div class="card p-8 reveal delay-2">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-8 rounded-lg bg-[var(--color-forest)]/[0.08] flex items-center justify-center">
              <svg class="w-4 h-4 text-[var(--color-forest)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            </div>
            <h3 class="text-base font-semibold text-[var(--color-ink)]">{t['p1-title']}</h3>
          </div>
          <p class="text-[var(--color-ink-muted)] text-[15px] leading-relaxed">{t['p1-desc']}</p>
        </div>
        <div class="card p-8 reveal delay-3">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-8 rounded-lg bg-[var(--color-forest)]/[0.08] flex items-center justify-center">
              <svg class="w-4 h-4 text-[var(--color-forest)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
            <h3 class="text-base font-semibold text-[var(--color-ink)]">{t['p2-title']}</h3>
          </div>
          <p class="text-[var(--color-ink-muted)] text-[15px] leading-relaxed">{t['p2-desc']}</p>
        </div>
        <div class="card p-8 reveal delay-4">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-8 rounded-lg bg-[var(--color-forest)]/[0.08] flex items-center justify-center">
              <svg class="w-4 h-4 text-[var(--color-forest)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
            </div>
            <h3 class="text-base font-semibold text-[var(--color-ink)]">{t['p3-title']}</h3>
          </div>
          <p class="text-[var(--color-ink-muted)] text-[15px] leading-relaxed">{t['p3-desc']}</p>
        </div>
        <div class="card p-8 reveal delay-5">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-8 rounded-lg bg-[var(--color-forest)]/[0.08] flex items-center justify-center">
              <svg class="w-4 h-4 text-[var(--color-forest)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <h3 class="text-base font-semibold text-[var(--color-ink)]">{t['p4-title']}</h3>
          </div>
          <p class="text-[var(--color-ink-muted)] text-[15px] leading-relaxed">{t['p4-desc']}</p>
        </div>
      </div>
    </div>
  </section>


  <section id="open-source" class="py-24 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <p class="pill bg-[var(--color-forest)]/[0.06] text-[var(--color-forest)] border border-[var(--color-forest)]/10 mb-6 reveal">{t['os-badge']}</p>
      <h2 class="headline-serif text-4xl md:text-5xl text-[var(--color-ink)] mb-6 reveal delay-1">
        <span>{t['os-h2-1']}</span><br/><span class="italic text-[var(--color-sage)]">{t['os-h2-2']}</span>
      </h2>
      <p class="text-[var(--color-ink-muted)] text-lg mb-10 max-w-xl mx-auto leading-relaxed reveal delay-2">{t['os-sub']}</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 reveal delay-3">
        <a href="https://github.com" target="_blank" class="px-6 py-3 rounded-full border border-[var(--color-ink)] text-[var(--color-ink)] font-medium text-sm hover:bg-[var(--color-ink)] hover:text-white transition-all flex items-center gap-2">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          <span>{t['os-github']}</span>
        </a>
        <a href="/app" class="px-6 py-3 rounded-full bg-[var(--color-forest)] text-white font-medium text-sm hover:bg-[var(--color-forest-light)] transition-all">{t['os-try']}</a>
      </div>
    </div>
  </section>


  <section class="py-24 px-6">
    <div class="max-w-2xl mx-auto">
      <div class="card p-12 md:p-16 text-center reveal-scale border-[var(--color-forest)]/10 hover:border-[var(--color-forest)]/20 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-forest)]/[0.02] to-[var(--color-teal)]/[0.03] pointer-events-none"></div>
        <div class="relative">
          <h2 class="headline-serif text-3xl md:text-4xl text-[var(--color-ink)] mb-4">
            <span>{t['cta-h2-1']}</span><span class="italic text-[var(--color-sage)]">{t['cta-h2-2']}</span>
          </h2>
          <p class="text-[var(--color-ink-muted)] mb-8">{t['cta-sub']}</p>
          <a href="/app" class="inline-flex px-8 py-3.5 rounded-full bg-[var(--color-forest)] text-white font-medium hover:bg-[var(--color-forest-light)] transition-all hover:shadow-xl hover:shadow-[var(--color-forest)]/15 hover:-translate-y-0.5">{t['cta-btn']}</a>
        </div>
      </div>
    </div>
  </section>


  <Footer lang="de" />

</Layout>
