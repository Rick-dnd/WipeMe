---
import JsonLd from './JsonLd.astro';
import { generateBreadcrumbJsonLd } from '../lib/seo.ts';

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="text-sm text-[var(--color-ink-muted)] mb-6">
  <ol class="flex items-center gap-1.5 flex-wrap">
    {items.map((item, i) => (
      <li class="flex items-center gap-1.5">
        {i > 0 && <span class="text-[var(--color-sand)]">/</span>}
        {i < items.length - 1 ? (
          <a href={new URL(item.url).pathname} class="hover:text-[var(--color-forest)] transition-colors">
            {item.name}
          </a>
        ) : (
          <span class="text-[var(--color-ink)]">{item.name}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<JsonLd data={generateBreadcrumbJsonLd(items)} />
